// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Company {
  id           String  @id @default(cuid())
  slug         String  @unique
  name         String
  oneLiner     String?
  description  String?
  logoUrl      String?
  vcBacker     String?
  industry     String?
  employees    String?
  location     String?
  foundedYear  Int?
  website      String?
  twitterUrl   String?
  linkedinUrl  String?
  tags         String?
  ycUrl        String?

  founders Founder[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Founder {
  id        String  @id @default(cuid())
  companyId String
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  name        String
  role        String?
  email       String?
  phone       String?
  avatarUrl   String?
  twitterUrl  String?
  linkedinUrl String?
  bio         String?

  generatedMessages GeneratedMessage[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model User {
  id         String   @id @default(cuid())
  firebaseId String   @unique
  email      String   @unique
  resumeText String?
  
  generatedMessages GeneratedMessage[]

  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model GeneratedMessage {
  id        String   @id @default(cuid())
  userId    String
  founderId String
  content   String
  
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  founder   Founder  @relation(fields: [founderId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, founderId])
}
